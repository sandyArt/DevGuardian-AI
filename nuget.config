<?xml version="1.0" encoding="utf-8"?>
<!--
  This nuget.config ensures that packages are restored from the official
  NuGet.org feed regardless of any machine-level NuGet.config that points
  to a private registry.

  Remove (or rename) this file if your organisation provides these packages
  through a private feed.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
